{
  "name": "@nova/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "./main/index.js",
  "scripts": {
    "dev": "bun run build:main && concurrently -k \"vite --config renderer/vite.config.ts\" \"electron .\"",
    "dev:vite": "vite --config renderer/vite.config.ts",
    "dev:electron": "bun run build:main && electron .",
    "build:main": "tsc -p main/tsconfig.json",
    "build:renderer": "vite build renderer",
    "build": "bun run build:main && bun run build:renderer",
    "typecheck": "tsc --noEmit -p main/tsconfig.json && tsc --noEmit -p renderer/tsconfig.json"
  },
  "dependencies": {
    "@nova/engine": "workspace:*",
    "@nova/shared": "workspace:*",
    "@types/node-telegram-bot-api": "^0.64.15",
    "@types/prismjs": "^1.26.6",
    "electron-updater": "6.6.2",
    "node-telegram-bot-api": "^1.1.0",
    "prismjs": "^1.30.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "10.4.21",
    "electron": "35.2.1",
    "electron-builder": "26.0.12",
    "postcss": "8.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwindcss": "4.1.8",
    "typescript": "5.8.3",
    "vite": "6.3.5",
    "zustand": "5.0.5"
  }
}
